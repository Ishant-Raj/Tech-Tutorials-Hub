# ─────────────────────────────────────────────────────────────────
#  Tech Tutorials Hub — Environment Variables
#  Copy this file:  cp .env.example .env
#  Then fill in the values below.
# ─────────────────────────────────────────────────────────────────

# Port the Express server listens on
PORT=5000

# MongoDB connection string
# Local MongoDB:  mongodb://localhost:27017/tech_tutorials
# MongoDB Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/tech_tutorials
# For Render: Set MONGO_URI in Render Dashboard Environment Variables
MONGO_URI=

# JWT secret — use a long, random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# For Render: Set JWT_SECRET in Render Dashboard Environment Variables
JWT_SECRET=

# JWT expiry (e.g. 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# Frontend URL(s) used for CORS — comma-separated for multiple origins
# VS Code Live Server default: http://127.0.0.1:5500
# Add production URL when deploying: http://127.0.0.1:5500,https://yourapp.com
CLIENT_URL=http://127.0.0.1:5500

# Node environment: development | production
NODE_ENV=development
